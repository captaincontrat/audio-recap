{
  "name": "audio-recap-workspace",
  "private": true,
  "description": "pnpm workspace for the Audio Recap CLI and future web app",
  "scripts": {
    "check": "pnpm --filter ./app --filter ./libs/audio-recap check",
    "format": "pnpm --filter ./app --filter ./libs/audio-recap format",
    "lint": "pnpm --filter ./app --filter ./libs/audio-recap lint",
    "process:meeting": "pnpm --filter ./libs/audio-recap process:meeting",
    "typecheck": "pnpm --filter ./app --filter ./libs/audio-recap typecheck"
  }
}
