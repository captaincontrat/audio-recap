{
  "name": "audio-recap",
  "version": "1.0.0",
  "description": "CLI to transcribe and summarize meeting audio with OpenAI and ffmpeg",
  "scripts": {
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "process:meeting": "tsx src/cli.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "license": "ISC",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./pipeline": "./src/pipeline/process-meeting.ts",
    "./audio": "./src/audio/ffmpeg.ts",
    "./domain/transcript": "./src/domain/transcript.ts",
    "./domain/timestamps": "./src/domain/timestamps.ts",
    "./openai/summarize": "./src/openai/summarize.ts",
    "./openai/title": "./src/openai/title.ts",
    "./openai/transcribe": "./src/openai/transcribe.ts",
    "./render": "./src/render/markdown.ts"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "openai": "^6.32.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "private": true
}
