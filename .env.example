OPENAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

DATABASE_URL=postgres://audio_recap:audio_recap@localhost:6543/audio_recap
REDIS_URL=redis://localhost:6381

BETTER_AUTH_SECRET=replace-with-a-strong-random-secret-of-32-plus-characters
BETTER_AUTH_URL=http://localhost:3000

# Federated sign-in (Google OAuth + One Tap). Leave the server-side values
# empty to keep the Google buttons hidden in the UI; set them together with
# the `NEXT_PUBLIC_` copy so the browser can initialize One Tap too.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# WebAuthn passkey settings. In local dev `localhost` and the default
# origin derived from BETTER_AUTH_URL work out of the box.
PASSKEY_RP_ID=localhost
PASSKEY_RP_NAME=Summitdown
PASSKEY_ORIGIN=http://localhost:3000

EMAIL_PROVIDER=console
EMAIL_FROM=no-reply@summitdown.local

AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

LOG_LEVEL=info
